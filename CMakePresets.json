{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 21, "patch": 0},
  "configurePresets": [
    {"name":"base","hidden":true,"binaryDir":"${sourceDir}/.cmake-build/${presetName}","cacheVariables":{"CMAKE_BUILD_TYPE":"Release","ORZ_BUILD_TESTS":"ON"}},
    {"name":"macos-arm64","inherits":"base","cacheVariables":{"CMAKE_OSX_ARCHITECTURES":"arm64","ORZ_PROFILE":"full","ORZ_BUILD_SHARED":"ON"}},
    {"name":"macos-x86_64","inherits":"base","cacheVariables":{"CMAKE_OSX_ARCHITECTURES":"x86_64","ORZ_PROFILE":"full","ORZ_BUILD_SHARED":"ON"}},
    {"name":"ios-device-lite","inherits":"base","cacheVariables":{"CMAKE_SYSTEM_NAME":"iOS","CMAKE_OSX_SYSROOT":"iphoneos","CMAKE_OSX_ARCHITECTURES":"arm64","CMAKE_OSX_DEPLOYMENT_TARGET":"15.0","ORZ_PROFILE":"builtin-lite","ORZ_BUILD_TESTS":"OFF"}},
    {"name":"ios-simulator-lite","inherits":"base","cacheVariables":{"CMAKE_SYSTEM_NAME":"iOS","CMAKE_OSX_SYSROOT":"iphonesimulator","CMAKE_OSX_ARCHITECTURES":"arm64;x86_64","CMAKE_OSX_DEPLOYMENT_TARGET":"15.0","ORZ_PROFILE":"builtin-lite","ORZ_BUILD_TESTS":"OFF"}},
    {"name":"linux-x86_64","inherits":"base","cacheVariables":{"ORZ_PROFILE":"server","ORZ_BUILD_SHARED":"ON"}},
    {"name":"builtin-lite","inherits":"base","cacheVariables":{"ORZ_PROFILE":"builtin-lite"}},
    {"name":"wasm-full","inherits":"base","toolchainFile":"$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake","cacheVariables":{"ORZ_PROFILE":"full","ORZ_BUILD_TESTS":"OFF"}},
    {"name":"wasm-lite","inherits":"base","toolchainFile":"$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake","cacheVariables":{"ORZ_PROFILE":"builtin-lite","ORZ_BUILD_TESTS":"OFF"}}
  ],
  "buildPresets": [
    {"name":"macos-arm64","configurePreset":"macos-arm64"},
    {"name":"macos-x86_64","configurePreset":"macos-x86_64"},
    {"name":"ios-device-lite","configurePreset":"ios-device-lite"},
    {"name":"ios-simulator-lite","configurePreset":"ios-simulator-lite"},
    {"name":"linux-x86_64","configurePreset":"linux-x86_64"},
    {"name":"builtin-lite","configurePreset":"builtin-lite"},
    {"name":"wasm-full","configurePreset":"wasm-full"},
    {"name":"wasm-lite","configurePreset":"wasm-lite"}
  ]
}
