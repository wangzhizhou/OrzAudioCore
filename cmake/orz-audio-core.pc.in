prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: OrzAudioCore
Description: Versioned cross-platform chiptune decoder ABI
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lOrzAudioCore
Libs.private: -lz
Cflags: -I${includedir}
